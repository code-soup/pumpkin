{
    "name": "wordpress-pumpkin-theme",
    "type": "module",
    "version": "1.0.0",
    "license": "GPL-3.0",
    "keywords": [
        "theme",
        "wordpress",
        "wordpress theme",
        "wordpress theme boilerplate"
    ],
    "description": "WordPress theme boilerplate",
    "repository": {
        "type": "git",
        "url": "https://github.com/code-soup/pumpkin.git"
    },
    "bugs": {
        "url": "https://github.com/code-soup/pumpkin/issues"
    },
    "engines": {
        "node": ">=20.9.0"
    },
    "authors": [
        {
            "homepage": "https://www.bobz.co",
            "name": "Vlado Bosnjak",
            "email": "vb@bobz.co"
        },
        {
            "homepage": "https://www.codesoup.co",
            "name": "Code Soup",
            "email": "hi@codesoup.co"
        }
    ],
    "browserslist": [
        "> 1%",
        "last 3 versions",
        "android 4",
        "safari 10",
        "not ie <= 8"
    ],
    "scripts": {
        "dev": "webpack serve --hot --mode development --color --config src/config/config.webpack.js",
        "build": "webpack --mode development --progress --config src/config/config.webpack.js",
        "build:prod": "webpack --mode production --progress --config src/config/config.webpack.js",
        "lint": "npm run -s lint:scripts && npm run -s lint:styles",
        "lint:scripts": "eslint src/scripts src/webpack",
        "lint:styles": "stylelint \"src/styles/**/*.{css,sass,scss}\"",
        "reinit": "rimraf dist && rimraf node_modules && yarn",
        "clean": "rimraf dist"
    },
    "devDependencies": {
        "@babel/core": "^7.28.4",
        "@babel/plugin-proposal-class-properties": "^7.18.6",
        "@babel/preset-env": "^7.28.3",
        "@prettier/plugin-php": "^0.24.0",
        "babel-loader": "^10.0.0",
        "breakpoint-sass": "^3.0.0",
        "clean-webpack-plugin": "^4.0.0",
        "css-loader": "^7.1.2",
        "css-minimizer-webpack-plugin": "^7.0.2",
        "cssnano": "^7.1.1",
        "dotenv": "^17.2.2",
        "eslint": "^9.35.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-webpack-plugin": "^5.0.2",
        "import-glob": "^1.5.0",
        "jquery": "^3.7.1",
        "mini-css-extract-plugin": "^2.9.4",
        "postcss": "^8.5.6",
        "postcss-loader": "^8.2.0",
        "postcss-preset-env": "^10.3.1",
        "prettier": "^3.6.2",
        "regenerator-runtime": "^0.14.1",
        "resolve-url-loader": "^5.0.0",
        "rimraf": "^6.0.1",
        "sass": "^1.92.1",
        "sass-loader": "^16.0.5",
        "style-loader": "^4.0.0",
        "stylelint": "^16.23.1",
        "stylelint-config-property-sort-order-smacss": "^10.0.0",
        "stylelint-config-standard-scss": "^15.0.1",
        "stylelint-order": "^7.0.0",
        "stylelint-webpack-plugin": "^5.0.1",
        "svg-spritemap-webpack-plugin": "^5.0.1",
        "webpack": "^5.101.3",
        "webpack-bundle-analyzer": "^4.10.2",
        "webpack-cli": "^6.0.1",
        "webpack-dev-server": "^5.2.2",
        "webpack-hot-middleware": "^2.26.1",
        "webpack-manifest-plugin": "^5.0.1",
        "webpack-merge": "^6.0.1",
        "yargs": "~18.0.0"
    },
    "dependencies": {}
}
